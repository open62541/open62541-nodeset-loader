<?xml version="1.0" encoding="utf-8"?>
<UANodeSet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd" xsi:schemaLocation="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd http://opcfoundation.org/UA/2011/03/UANodeSet.xsd">
  <NamespaceUris>
    <Uri>http://open62541.org/test/inverseEncoding/</Uri>
  </NamespaceUris>
  <Aliases>
    <Alias Alias="HasEncoding">i=38</Alias>
    <Alias Alias="HasSubtype">i=45</Alias>
    <Alias Alias="HasTypeDefinition">i=40</Alias>
    <Alias Alias="Organizes">i=35</Alias>
    <Alias Alias="Structure">i=22</Alias>
  </Aliases>

  <!-- Custom DataType with FORWARD HasEncoding references (discoverable by current implementation) -->
  <UADataType NodeId="ns=1;i=5001" BrowseName="1:ForwardOnlyStructType">
    <DisplayName>ForwardOnlyStructType</DisplayName>
    <Description LocalizedText="A custom structure type with forward HasEncoding references for discoverable encoding IDs"/>
    <References>
      <Reference ReferenceType="HasSubtype" IsForward="false">i=22</Reference>
      <Reference ReferenceType="HasEncoding">ns=1;i=5002</Reference> <!-- binary -->
    </References>
    <Definition Name="ForwardOnlyStructType">
      <Field Name="Value1" DataType="i=7"/>
      <Field Name="Value2" DataType="i=3"/>
    </Definition>
  </UADataType>

  <!-- Second datatype demonstrating that both directions work for HasEncoding -->
  <UADataType NodeId="ns=1;i=5010" BrowseName="1:InverseOnlyStructType">
    <DisplayName>InverseOnlyStructType</DisplayName>
    <Description LocalizedText="A custom structure type with HasEncoding references. The encoding objects also define inverse refs back to this type. Both directions should be supported for discovery."/>
    <References>
      <Reference ReferenceType="HasSubtype" IsForward="false">i=22</Reference>
    </References>
    <Definition Name="InverseOnlyStructType">
      <Field Name="Field1" DataType="i=3"/>
      <Field Name="Field2" DataType="i=7"/>
    </Definition>
  </UADataType>

  <!-- Encoding objects for ForwardOnlyStructType (forward refs discoverable) -->
  <UAObject NodeId="ns=1;i=5002" BrowseName="Default Binary">
    <DisplayName>Default Binary</DisplayName>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=76</Reference>
      <Reference ReferenceType="HasEncoding" IsForward="false">ns=1;i=5001</Reference>
    </References>
  </UAObject>

  <!-- Encoding objects for InverseOnlyStructType (ONLY inverse refs - limitation case) -->
  <UAObject NodeId="ns=1;i=5011" BrowseName="Default Binary">
    <DisplayName>Default Binary</DisplayName>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=76</Reference>
      <Reference ReferenceType="HasEncoding" IsForward="false">ns=1;i=5010</Reference>
    </References>
  </UAObject>

</UANodeSet>
